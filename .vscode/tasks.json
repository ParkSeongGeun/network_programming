{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "${file}",
                "/Fe${fileDirname}\\build\\${fileBasenameNoExtension}.exe",
                "/Fo${fileDirname}\\build\\",
                "/Fd${fileDirname}\\build\\"
            ],
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}